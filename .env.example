# ============================================================
# .env.example — RekomendasiSahamV2
# Salin file ini menjadi ".env" untuk development lokal.
# Untuk production (Fly.io), gunakan:
#   fly secrets set HF_API_KEY=hf_xxx MODEL_API_URL=https://...
# ============================================================

# ── HuggingFace Inference API ────────────────────────────────
# Token dari https://huggingface.co/settings/tokens
HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── URL endpoint model ────────────────────────────────────────
# Gunakan HuggingFace Inference API standar untuk IndoBERT:
#   https://api-inference.huggingface.co/models/mdhugol/indonesia-bert-sentiment-classification
#
# Atau URL custom GPU endpoint (Hugging Face Inference Endpoints / Spaces):
#   https://your-endpoint.endpoints.huggingface.cloud
#
# Jika MODEL_API_URL dikosongkan (""), sentiment_analyzer.py akan
# menggunakan endpoint standar HF secara otomatis berdasarkan HF_API_KEY.
MODEL_API_URL=

# ── Flask ─────────────────────────────────────────────────────
# "true" untuk development, "false" untuk production
FLASK_DEBUG=true
PORT=5000
